{
  "name": "campusblog",
  "version": "1.0.0",
  "description": "A blog system for campus based on Cloudflare and Payload",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" node ./scripts/with-wrangler-env.mjs next build --webpack",
    "build:dev": "cross-env CLOUDFLARE_ENV=dev node ./scripts/with-wrangler-env.mjs opennextjs-cloudflare build --env=dev",
    "build:production": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" node ./scripts/with-wrangler-env.mjs opennextjs-cloudflare build",
    "clean:build": "node ./scripts/clean-build-artifacts.mjs",
    "deploy": "pnpm run deploy:database && pnpm run deploy:app",
    "deploy:app": "pnpm run build:production && opennextjs-cloudflare deploy",
    "deploy:app:dev": "pnpm run build:dev && opennextjs-cloudflare deploy --env=dev",
    "deploy:app:production": "pnpm run deploy:app",
    "deploy:database": "cross-env NODE_ENV=production PAYLOAD_SECRET=ignore payload migrate && wrangler d1 execute D1 --command 'PRAGMA optimize' --remote",
    "deploy:database:dev": "cross-env CLOUDFLARE_ENV=dev NODE_ENV=production PAYLOAD_SECRET=ignore payload migrate && wrangler d1 execute D1 --command 'PRAGMA optimize' --env=dev --remote",
    "deploy:database:production": "pnpm run deploy:database",
    "deploy:dev": "pnpm run deploy:database:dev && pnpm run deploy:app:dev",
    "deploy:production": "pnpm run deploy:database:production && pnpm run deploy:app:production",
    "dev": "cross-env WRANGLER_CONFIG_PATH=wrangler.dev.jsonc NODE_OPTIONS=--no-deprecation node ./scripts/with-wrangler-env.mjs next dev",
    "devsafe": "pnpm run clean:build && cross-env WRANGLER_CONFIG_PATH=wrangler.dev.jsonc NODE_OPTIONS=--no-deprecation node ./scripts/with-wrangler-env.mjs next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "pnpm run generate:types:cloudflare && pnpm run generate:types:payload",
    "generate:types:cloudflare": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "generate:types:payload": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "ii": "pnpm install --ignore-workspace",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "preview": "pnpm run preview:production",
    "preview:dev": "pnpm run build:dev && opennextjs-cloudflare preview --env=dev",
    "preview:production": "pnpm run build:production && opennextjs-cloudflare preview",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.4",
    "@payloadcms/db-d1-sqlite": "^3.84.1",
    "@payloadcms/next": "^3.84.1",
    "@payloadcms/storage-r2": "^3.84.1",
    "@payloadcms/ui": "^3.84.1",
    "@tabler/icons-react": "^3.41.1",
    "@tiptap/core": "^3.22.4",
    "@tiptap/extension-placeholder": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "graphql": "^16.13.2",
    "next": "16.2.4",
    "payload": "^3.84.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "shadcn": "^4.4.0",
    "slugify": "^1.6.9",
    "tailwind-merge": "^3.5.0",
    "transliteration": "^2.6.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "1.59.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "22.19.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "29.0.2",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.4",
    "wrangler": "^4.84.1"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msw",
      "sharp",
      "unrs-resolver",
      "workerd"
    ]
  },
  "cloudflare": {
    "bindings": {
      "PAYLOAD_SECRET": {
        "description": "Generate a random string using `openssl rand -hex 32`"
      }
    }
  },
  "packageManager": "pnpm@10.33.1+sha512.05ba3c1d5d1c18f68df06470d74055e62d41fc110a0c660db1b2dfb2785327f04cf0f68345d4609bc52089e7fa0343c31593b2f9594e2c5d5da426230acc9820"
}
